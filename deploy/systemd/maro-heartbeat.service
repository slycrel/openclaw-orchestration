[Unit]
Description=Maro Heartbeat — optional health monitor (manual runs do not require this service)
# Update Documentation path if repo location changes
Documentation=file:///home/clawd/claude/maro-orchestration/CLAUDE.md
After=network.target

[Service]
Type=simple
User=clawd
# NOTE: Update WorkingDirectory/PYTHONPATH if repo is moved.
# Use `scripts/heartbeat-ctl.sh` for path-independent startup instead.
# This service intentionally runs heartbeat in health-only mode by default.
# Pass --autonomy only in environments where always-on background execution
# is explicitly desired.
WorkingDirectory=/home/clawd/claude/maro-orchestration
ExecStart=/usr/bin/python3 src/heartbeat.py --loop --interval 60
Restart=on-failure
RestartSec=30

# Token budget safety: stop after 4 hours, require manual restart.
# Prevents multi-day unattended token burn like the Apr 7-9 incident.
RuntimeMaxSec=14400

# Environment — PYTHONPATH must match WorkingDirectory
# No MARO_MEMORY_DIR needed — defaults to ~/.maro/workspace/memory (same as config.py)
Environment=PYTHONPATH=/home/clawd/claude/maro-orchestration/src

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=maro-heartbeat

[Install]
WantedBy=default.target
